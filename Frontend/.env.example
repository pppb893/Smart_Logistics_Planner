VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here
VITE_OPENWEATHER_API_KEY=your_openweather_key_here

# Base URL of the backend API.
# - Leave empty when frontend and backend are served behind the same ingress/proxy
#   (e.g. K8s ingress that routes /api -> backend).
# - Set to a full host when calling a backend on a different origin
#   (e.g. http://localhost:5000 during local dev without proxy).
# A trailing "/api" is tolerated and will be stripped automatically.
VITE_API_URL=

NODE_ENV=production
